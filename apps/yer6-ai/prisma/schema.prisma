generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ENGINEER
  MANAGER
  ADMIN
}

enum ProjectStatus {
  DRAFT
  ANALYZING
  REVIEW
  COMPLETE
  ARCHIVED
}

enum DocumentStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum KnowledgeDocumentStatus {
  UPLOADED
  QUEUED
  PARSING
  CHUNKING
  EMBEDDING
  INDEXING
  READY
  FAILED
  ARCHIVED
}

enum KnowledgeDocumentScope {
  PROJECT
  COMPANY
  STANDARDS
}

enum StandardLicenseStatus {
  PUBLIC
  LICENSED_INTERNAL
  REFERENCE_ONLY
  RESTRICTED
}

enum MemoryScope {
  PROJECT
  COMPANY
}

enum MemoryType {
  CONVERSATION
  DOCUMENT
  ANALYSIS
  QUANTITY
  PRELIMINARY_COST
  PROPOSAL
  TECHNICAL_NOTE
  PROCEDURE
  EQUIPMENT
}

enum SpatialAssetKind {
  BIM
  DRONE
  POINT_CLOUD
  LIDAR
  GIS
  MODEL_3D
}

enum KnowledgeModuleKind {
  DOCUMENT
  STRUCTURED
  COMPUTE
}

enum StructuredRecordStatus {
  DRAFT
  READY
  INDEXING
  INDEXED
  FAILED
  ARCHIVED
}

enum IngestionJobKind {
  DOCUMENT
  STRUCTURED_IMPORT
  MODULE_REINDEX
}

enum IngestionJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum SpatialAssetStatus {
  REGISTERED
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  role               UserRole            @default(ENGINEER)
  accounts           Account[]
  sessions           Session[]
  projects           Project[]
  conversations      Conversation[]
  knowledgeDocuments KnowledgeDocument[]
  memoryRecords      MemoryRecord[]
  spatialAssets      SpatialAsset[]
  auditLogs          AuditLog[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id                 String              @id @default(cuid())
  name               String
  location           String?
  category           String
  status             ProjectStatus       @default(DRAFT)
  progress           Int                 @default(0)
  ownerId            String
  owner              User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documents          Document[]
  knowledgeDocuments KnowledgeDocument[]
  memoryRecords      MemoryRecord[]
  spatialAssets      SpatialAsset[]
  conversations      Conversation[]
  analyses           Analysis[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([ownerId, updatedAt])
}

model Document {
  id        String         @id @default(cuid())
  name      String
  type      String
  size      Int
  url       String
  key       String         @unique
  status    DocumentStatus @default(UPLOADING)
  projectId String
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([projectId, createdAt])
}

model Conversation {
  id        String    @id @default(cuid())
  title     String
  userId    String
  projectId String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  role           MessageRole
  content        String       @db.Text
  citations      Json?
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model Analysis {
  id        String   @id @default(cuid())
  title     String
  summary   String   @db.Text
  data      Json
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model KnowledgeDocument {
  id                     String                  @id @default(cuid())
  name                   String
  extension              String
  mimeType               String
  size                   Int
  category               String
  scope                  KnowledgeDocumentScope
  moduleKey              String?
  partition              String?
  projectId              String?
  organizationId         String?
  storageProvider        String
  storageKey             String                  @unique
  sourceUrl              String?
  checksum               String?
  version                String?
  standardId             String?
  licenseStatus          StandardLicenseStatus?
  contentIndexingAllowed Boolean                 @default(true)
  status                 KnowledgeDocumentStatus @default(UPLOADED)
  parserVersion          String?
  embeddingProvider      String?
  embeddingModel         String?
  vectorProvider         String?
  chunkCount             Int                     @default(0)
  tokenCount             Int                     @default(0)
  metadata               Json?
  errorCode              String?
  errorMessage           String?                 @db.Text
  uploadedById           String?
  project                Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploadedBy             User?                   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  standard               EngineeringStandard?    @relation(fields: [standardId], references: [id], onDelete: SetNull)
  chunks                 KnowledgeChunk[]
  indexedAt              DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([category, status, updatedAt])
  @@index([projectId, status])
  @@index([organizationId, status])
  @@index([standardId, status])
  @@index([uploadedById, createdAt])
  @@index([moduleKey, partition, status])
}

model EngineeringStandard {
  id                     String                @id @default(cuid())
  family                 String
  code                   String
  title                  String
  edition                String?
  version                String?
  publishedAt            DateTime?
  licenseStatus          StandardLicenseStatus @default(REFERENCE_ONLY)
  contentIndexingAllowed Boolean               @default(false)
  rightsHolder           String?
  sourceReference        String?
  usageNote              String?               @db.Text
  active                 Boolean               @default(true)
  documents              KnowledgeDocument[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@unique([family, code, version])
  @@index([family, active, updatedAt])
  @@index([licenseStatus, contentIndexingAllowed])
}

model MemoryRecord {
  id             String      @id @default(cuid())
  scope          MemoryScope
  type           MemoryType
  title          String
  content        String      @db.Text
  structuredData Json?
  projectId      String?
  organizationId String?
  sourceType     String?
  sourceId       String?
  createdById    String?
  project        Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy      User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([projectId, type, updatedAt])
  @@index([organizationId, type, updatedAt])
  @@index([sourceType, sourceId])
}

model SpatialAsset {
  id             String             @id @default(cuid())
  kind           SpatialAssetKind
  status         SpatialAssetStatus @default(REGISTERED)
  name           String
  projectId      String?
  organizationId String?
  storageKey     String?
  sourceUrl      String?
  coordinateRef  String?
  metadata       Json?
  createdById    String?
  project        Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy      User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([projectId, kind, updatedAt])
  @@index([organizationId, kind, updatedAt])
}

model KnowledgeChunk {
  id            String            @id
  documentId    String
  ordinal       Int
  content       String            @db.Text
  contentHash   String
  tokenEstimate Int
  page          Int?
  section       String?
  vectorId      String            @unique
  metadata      Json?
  document      KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())

  @@unique([documentId, ordinal])
  @@index([documentId, createdAt])
  @@index([contentHash])
}

/// Module 7 — Machine Database. Structured rig specifications, replacing the
/// hardcoded equipment array. Every row is queryable in Postgres and, once
/// indexed, semantically searchable via Vectorize (namespace mod:machine[:mfg]).
model MachineRig {
  id             String                 @id @default(cuid())
  manufacturer   String
  model          String
  partition      String?
  category       String?
  torque         Float?
  maxDepth       Float?
  maxDiameter    Float?
  weight         Float?
  enginePower    Float?
  applications   String[]
  advantages     String[]
  limitations    String[]
  specifications Json?
  source         String?
  checksum       String
  status         StructuredRecordStatus @default(READY)
  vectorId       String?                @unique
  indexedAt      DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([manufacturer, model])
  @@index([partition, status])
  @@index([status, updatedAt])
}

/// Module 8 — Soil Database. Structured soil profiles/parameters. Layers are
/// stored inline as JSON for flexibility; index properties are promoted to
/// columns for filtering and feasibility queries.
model SoilProfile {
  id             String                 @id @default(cuid())
  name           String
  partition      String?
  classification String?
  location       String?
  latitude       Float?
  longitude      Float?
  depthFrom      Float?
  depthTo        Float?
  groundwater    Float?
  parameters     Json?
  layers         Json?
  sourceReportId String?
  source         String?
  checksum       String
  status         StructuredRecordStatus @default(READY)
  vectorId       String?                @unique
  indexedAt      DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([partition, status])
  @@index([classification, status])
  @@index([status, updatedAt])
}

/// Module 10 — Engineering Decision Engine. Declarative rules evaluated against
/// a normalized site/design context to produce ranked recommendations.
model DecisionRule {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  category    String
  description String?  @db.Text
  priority    Int      @default(100)
  conditions  Json
  outcome     Json
  references  String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, active, priority])
}

/// Tracks ingestion / import / reindex work so large, incremental jobs are
/// observable and resumable at platform scale.
model IngestionJob {
  id           String             @id @default(cuid())
  kind         IngestionJobKind
  moduleKey    String?
  partition    String?
  status       IngestionJobStatus @default(QUEUED)
  totalItems   Int                @default(0)
  processed    Int                @default(0)
  succeeded    Int                @default(0)
  failed       Int                @default(0)
  cursor       String?
  detail       Json?
  errorMessage String?            @db.Text
  startedAt    DateTime?
  finishedAt   DateTime?
  createdById  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([kind, status, updatedAt])
  @@index([moduleKey, status])
}

// ===========================================================================
// Module 11 — Commercial Proposal Engine.
// Every commercial offer produces an official, verified PDF. Numbers and issued
// revisions are immutable; internal cost data is isolated from client output.
// Status / audience / currency / locale / kind are stored as validated strings
// (see src/server/proposals/domain/types.ts) to keep the enum surface stable.
// ===========================================================================

/// A logical offer, identified by an immutable offer number. Holds the latest
/// status pointer; the full history lives in ProposalRevision.
model Proposal {
  id              String             @id @default(cuid())
  organizationId  String
  projectId       String?
  offerNumber     String             @unique
  year            Int
  sequence        Int
  kind            String
  pricing         String
  currency        String
  locale          String
  customerName    String
  projectName     String
  subject         String
  status          String             @default("draft")
  currentRevision Int                @default(0)
  createdById     String?
  revisions       ProposalRevision[]
  events          ProposalEvent[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([organizationId, status, updatedAt])
  @@index([organizationId, year, sequence])
  @@index([projectId])
}

/// One immutable revision (R0, R1, ...). The full ProposalContent snapshot and
/// computed totals are stored verbatim so an issued PDF can always be re-derived
/// or audited. `immutable` is set once the revision is issued.
model ProposalRevision {
  id                  String         @id @default(cuid())
  proposalId          String
  proposal            Proposal       @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  revision            Int
  status              String         @default("draft")
  locale              String
  currency            String
  content             Json
  totals              Json?
  internalTotals      Json?
  grandTotal          Decimal?       @db.Decimal(18, 2)
  reason              String?
  priceBookRevision   String?
  templateRevision    String?
  calculationRevision String?
  checksum            String?
  immutable           Boolean        @default(false)
  createdById         String?
  approvedAt          DateTime?
  sentAt              DateTime?
  acceptedAt          DateTime?
  items               ProposalItem[]
  pdfs                ProposalPdf[]
  events              ProposalEvent[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([proposalId, revision])
  @@index([proposalId, status])
}

/// Normalized, queryable copy of each proposal line. Every line retains its
/// full provenance (origin, audience, source, currency) per section J.
model ProposalItem {
  id             String           @id @default(cuid())
  revisionId     String
  rev            ProposalRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  ordinal        Int
  description    String
  quantity       Decimal          @db.Decimal(18, 4)
  unit           String
  unitPrice      Decimal          @db.Decimal(18, 4)
  currency       String
  lineTotal      Decimal          @db.Decimal(18, 2)
  quantityOrigin String
  optional       Boolean          @default(false)
  vatApplicable  Boolean          @default(true)
  audience       String           @default("client")
  category       String?
  source         String?
  createdAt      DateTime         @default(now())

  @@index([revisionId, ordinal])
}

/// A generated, verified PDF artifact. There is at most one PDF per
/// (revision, audience, locale); approved artifacts are never overwritten.
model ProposalPdf {
  id              String           @id @default(cuid())
  revisionId      String
  rev             ProposalRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  audience        String
  locale          String
  storageProvider String           @default("r2")
  storageKey      String           @unique
  fileName        String
  byteSize        Int              @default(0)
  pageCount       Int              @default(0)
  checksum        String
  verified        Boolean          @default(false)
  verifiedAt      DateTime?
  grandTotal      Decimal?         @db.Decimal(18, 2)
  offerNumber     String
  metadata        Json?
  failureCategory String?
  createdById     String?
  createdAt       DateTime         @default(now())

  @@unique([revisionId, audience, locale])
  @@index([revisionId])
}

/// Per-organization, per-year monotonic sequence for transactional, gap-free,
/// duplicate-proof offer number allocation.
model ProposalNumberSequence {
  id             String   @id @default(cuid())
  organizationId String
  year           Int
  lastSequence   Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, year])
}

/// Versioned corporate proposal templates. The latest approved template is the
/// default; older approved templates are preserved as versioned records.
model ProposalTemplate {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  name           String
  version        Int      @default(1)
  approved       Boolean  @default(false)
  isDefault      Boolean  @default(false)
  config         Json
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, key, version])
  @@index([organizationId, isDefault])
}

/// Immutable audit trail for a proposal (creation, preview, download, approval,
/// sending, sharing, acceptance, rejection, revision, expiry, archival, failure).
model ProposalEvent {
  id         String            @id @default(cuid())
  proposalId String
  proposal   Proposal          @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  revisionId String?
  rev        ProposalRevision? @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  pdfId      String?
  type       String
  category   String?
  actorId    String?
  metadata   Json?
  createdAt  DateTime          @default(now())

  @@index([proposalId, createdAt])
  @@index([revisionId])
}
